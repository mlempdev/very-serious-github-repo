[ext_resource type="Script" uid="uid://bd6vca075g71m" path="res://src/scripts/Dialogues/Dialogue_JSON.gd" id="1_agtrx"]

[resource]
script = ExtResource("1_agtrx")
dialogue_lines = Array[String](["\"Welcome Everybody! Thank you so much for coming today!\"", "\"Welcome! To Wheel of Damnation!\"", "\"Today we've got a very special guest with us today. And we are gonna see if she has what it takes to survive...\"", "\"THE WHEEL OF DAMNATION!!!\"", "That's right! You're watching the best and only show in the nine layers! Made specifically for your demonic entertainment by our mysterious and terrifying producer! Now don't be scared dear. You signed the contract. It's not as though if you lose you'll go to hell or anything!\"", "\"Now come on Sam, don't be a spoil sport! Why don't you go ahead and give it a shot. Audience, what should she do?\"", "\"SPIN THE WHEEL!!\"", "\"That's right! Sam, go ahead and spin the Wheel of Daaammnnation!\""])
metadata/_custom_type_script = "uid://bd6vca075g71m"
